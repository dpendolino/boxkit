FROM quay.io/toolbx-images/alpine-toolbox:edge

LABEL com.github.containers.toolbox="true" \
      usage="This image is meant to be used with the toolbox or distrobox command" \
      summary="A cloud-native terminal experience" \
      maintainer="dpendolino@gmail.com"

COPY scripts/boxkit-alpine.sh /
COPY scripts/distrobox-shims.sh /
COPY packages/boxkit-alpine.packages /

RUN chmod +x /boxkit-alpine.sh /distrobox-shims.sh && /boxkit-alpine.sh
RUN rm /boxkit-alpine.sh /distrobox-shims.sh /boxkit-alpine.packages
